        "%%writefile /content/ai-multimedia-privacy-agent/thiqla_project/thiqla_live_agent.py\n",
        "import cv2\n",
        "import time\n",
        "import os\n",
        "import sys\n",
        "import numpy as np\n",
        "from typing import TypedDict\n",
        "from langgraph.graph import StateGraph, END\n",
        "\n",
        "# Conditional import for Colab display\n",
        "try:\n",
        "    from google.colab.patches import cv2_imshow\n",
        "    from IPython.display import display, clear_output\n",
        "    from PIL import Image # Explicitly import Image from PIL\n",
        "    IS_COLAB = True\n",
        "except ImportError:\n",
        "    IS_COLAB = False\n",
        "\n",
        "# --- LangGraph Engine Configuration (copied from thiqla_api.py) ---\n",
        "class LivestreamState(TypedDict):\n",
        "    face_detected: bool\n",
        "    duration_violating: float\n",
        "    system_alert: str\n",
        "\n",
        "def supervisor_node(state: LivestreamState):\n",
        "    face_present = state.get(\"face_detected\", False)\n",
        "    current_duration = state.get(\"duration_violating\", 0.0)\n",
        "\n",
        "    alert = \"✅ STATUS: PRIVACY CLEAN\"\n",
        "    if face_present:\n",
        "        if current_duration >= 3.0:\n",
        "            alert = f\"🚨 CRITICAL: FACE DETECTED TOO LONG ({current_duration:.1f}s)\"\n",
        "        else:\n",
        "            alert = f\"⚠️ WARNING: SHARIA GUARDRAIL ACTIVE ({current_duration:.1f}s)\"\n",
        "\n",
        "    return {\"system_alert\": alert}\n",
        "\n",
        "def compile_agent():\n",
        "    workflow = StateGraph(LivestreamState)\n",
        "    workflow.add_node(\"supervisor\", supervisor_node)\n",
        "    workflow.set_entry_point(\"supervisor\")\n",
        "    workflow.add_edge(\"supervisor\", END)\n",
        "    return workflow.compile()\n",
        "\n",
        "# Inisialisasi Agent Tunggal & Face Cascade\n",
        "agent = compile_agent()\n",
        "face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + 'haarcascade_frontalface_default.xml')\n",
        "\n",
        "# --- Video Source Configuration ---\n",
        "# Determine video source based on environment\n",
        "video_source = 0 # Default to webcam\n",
        "if IS_COLAB:\n",
        "    print(\"☁️ Mendeteksi Lingkungan Google Colab. Menggunakan file video: 'video_lokal_tes.mp4' sebagai simulasi webcam.\")\n",
        "    video_source = \"video_lokal_tes.mp4\"\n",
        "    if not os.path.exists(video_source):\n",
        "        print(f\"❌ ERROR: File '{video_source}' tidak ditemukan. Pastikan Anda telah menjalakan sel yang membuat video tes.\")\n",
        "        sys.exit(1)\n",
        "else:\n",
        "    print(\"🖥️ Lingkungan lokal terdeteksi. Mencoba menggunakan webcam (indeks 0).\")\n",
        "\n",
        "cap = cv2.VideoCapture(video_source)\n",
        "\n",
        "if not cap.isOpened():\n",
        "    print(f\"❌ Gagal mengakses Source ({video_source})! Pastikan file tersedia atau kamera tidak terkunci.\")\n",
        "    sys.exit(1)\n",
        "\n",
        "fps = cap.get(cv2.CAP_PROP_FPS) if cap.get(cv2.CAP_PROP_FPS) > 0 else 24\n",
        "width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH)) if cap.get(cv2.CAP_PROP_FRAME_WIDTH) > 0 else 640\n",
        "height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT)) if cap.get(cv2.CAP_PROP_FRAME_HEIGHT) > 0 else 480\n",
        "\n",
        "print(f\"🔄 Menyalakan Thiqla Live Engine pada Source: {video_source} ({width}x{height} @ {fps:.2f} FPS)...\")\n",
        "\n",
        "face_detected_status = False\n",
        "start_detection_time = None\n",
        "duration_violating = 0.0\n",
        "\n",
        "# Optimization parameters for faster face detection (copied from thiqla_api.py)\n",
        "detection_downscale_factor = 0.5\n",
        "detection_min_neighbors = 5\n",
        "detection_min_size = (int(40 * detection_downscale_factor), int(40 * detection_downscale_factor))\n",
        "\n",
        "frame_count = 0\n",
        "start_processing_time = time.time()\n",
        "\n",
        "while True:\n",
        "    ret, frame = cap.read()\n",
        "    if not ret:\n",
        "        print(\"End of video stream or failed to read frame.\")\n",
        "        break\n",
        "\n",
        "    frame_count += 1\n",
        "    processing_frame_start = time.time()\n",
        "\n",
        "    # Resize frame to a consistent size for display (e.g., 640x360 for better fit in colab)\n",
        "    display_width = 640\n",
        "    display_height = int(height * (display_width / width)) if width > 0 else 480\n",
        "    if display_width != width or display_height != height:\n",
        "        frame_for_display = cv2.resize(frame, (display_width, display_height))\n",
        "    else:\n",
        "        frame_for_display = frame.copy()\n",
        "\n",
        "\n",
        "    # Create a smaller version of the frame for faster face detection\n",
        "    small_frame = cv2.resize(frame, (0, 0), fx=detection_downscale_factor, fy=detection_downscale_factor, interpolation=cv2.INTER_AREA)\n",
        "    small_gray = cv2.cvtColor(small_frame, cv2.COLOR_BGR2GRAY)\n",
        "\n",
        "    # Perform face detection on the smaller frame\n",
        "    faces_detected_on_small = face_cascade.detectMultiScale(\n",
        "        small_gray,\n",
        "        scaleFactor=1.1,\n",
        "        minNeighbors=detection_min_neighbors,\n",
        "        minSize=detection_min_size\n",
        "    )\n",
        "\n",
        "    # Scale detected face coordinates back to the original frame size\n",
        "    faces = []\n",
        "    for (x, y, w, h) in faces_detected_on_small:\n",
        "        x_orig = int(x / detection_downscale_factor)\n",
        "        y_orig = int(y / detection_downscale_factor)\n",
        "        w_orig = int(w / detection_downscale_factor)\n",
        "        h_orig = int(h / detection_downscale_factor)\n",
        "        faces.append((x_orig, y_orig, w_orig, h_orig))\n",
        "\n",
        "    if len(faces) > 0:\n",
        "        face_detected_status = True\n",
        "        if start_detection_time is None:\n",
        "            start_detection_time = time.time()\n",
        "        duration_violating = time.time() - start_detection_time\n",
        "\n",
        "        for (x, y, w, h) in faces:\n",
        "            # Ensure coordinates are within frame bounds to prevent errors\n",
        "            y1, y2 = max(0, y), min(height, y + h)\n",
        "            x1, x2 = max(0, x), min(width, x + w)\n",
        "\n",
        "            if y2 > y1 and x2 > x1: # Ensure valid region\n",
        "                sub_face = frame_for_display[y1:y2, x1:x2]\n",
        "                kernel_size = 99\n",
        "                if sub_face.shape[0] < kernel_size or sub_face.shape[1] < kernel_size:\n",
        "                    kernel_size = min(sub_face.shape[0], sub_face.shape[1])\n",
        "                    kernel_size = kernel_size if kernel_size % 2 == 1 else kernel_size - 1\n",
        "                    kernel_size = max(1, kernel_size)\n",
        "\n",
        "                if kernel_size > 1:\n",
        "                    frame_for_display[y1:y2, x1:x2] = cv2.GaussianBlur(sub_face, (kernel_size, kernel_size), 15)\n",
        "                else:\n",
        "                    frame_for_display[y1:y2, x1:x2] = (0,0,0) # Fill with black if too small to blur\n",
        "\n",
        "    else:\n",
        "        face_detected_status = False\n",
        "        start_detection_time = None\n",
        "        duration_violating = 0.0\n",
        "\n",
        "    graph_output = agent.invoke({\n",
        "        \"face_detected\": face_detected_status,\n",
        "        \"duration_violating\": duration_violating,\n",
        "        \"system_alert\": \"\"\n",
        "    })\n",
        "    alert_text = graph_output[\"system_alert\"]\n",
        "\n",
        "    text_color = (0, 0, 255) if \"⚠️\" in alert_text or \"🚨\" in alert_text else (0, 255, 0)\n",
        "    cv2.rectangle(frame_for_display, (10, 10), (display_width - 10, 45), (0, 0, 0), -1)\n",
        "    cv2.putText(frame_for_display, alert_text, (20, 32), cv2.FONT_HERSHEY_SIMPLEX, 0.45, text_color, 2)\n",
        "\n",
        "    if IS_COLAB:\n",
        "        clear_output(wait=True) # Clear previous frame\n",
        "        cv2_imshow(frame_for_display)\n",
        "        # Simulate FPS with a delay\n",
        "        frame_processing_time = time.time() - processing_frame_start\n",
        "        delay = max(1, int((1000/fps - frame_processing_time*1000))) # Target 1/fps second per frame\n",
        "        #print(f\"Frame {frame_count}: Processing time {frame_processing_time:.4f}s, Delay {delay}ms\")\n",
        "        # In colab, using time.sleep is better for visual update than cv2.waitKey\n",
        "        time.sleep(delay / 1000.0)\n",
        "    else:\n",
        "        cv2.imshow('Thiqla Live Sanitization', frame_for_display)\n",
        "        if cv2.waitKey(1) & 0xFF == ord('q'):\n",
        "            break\n",
        "\n",
        "total_processing_time = time.time() - start_processing_time\n",
        "print(f\"Total processed frames: {frame_count}\")\n",
        "print(f\"Total live processing time: {total_processing_time:.2f} seconds.\")\n",
        "if frame_count > 0:\n",
        "    print(f\"Average FPS (processing + display): {frame_count / total_processing_time:.2f}\")\n",
        "\n",
        "cap.release()\n",
        "if not IS_COLAB:\n",
        "    cv2.destroyAllWindows()\n",
