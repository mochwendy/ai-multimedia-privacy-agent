        "%%writefile thiqla_api.py\n",
        "import os\n",
        "import cv2\n",
        "import time\n",
        "import shutil\n",
        "from typing import TypedDict\n",
        "from fastapi import FastAPI, UploadFile, File, HTTPException\n",
        "from fastapi.responses import FileResponse # Keep this for FileResponse in other routes if needed\n",
        "from fastapi.staticfiles import StaticFiles\n",
        "from fastapi.middleware.cors import CORSMiddleware # Added CORS\n",
        "\n",
        "from langgraph.graph import StateGraph, END\n",
        "\n",
        "# Inisialisasi FastAPI App\n",
        "app = FastAPI(\n",
        "    title=\"Thiqla AI Sharia Guardrail API\",\n",
        "    description=\"API Penyensoran Privasi Visual Otomatis berbasis LangGraph & OpenCV\",\n",
        "    version=\"1.0.0\"\n",
        ")\n",
        "\n",
        "# Menambahkan CORS agar Frontend bisa \"berbicara\" dengan Backend tanpa blokir\n",
        "app.add_middleware(\n",
        "    CORSMiddleware,\n",
        "    allow_origins=[\"*\"],\n",
        "    allow_methods=[\"*\"],\n",
        "    allow_headers=[\"*\"],\n",
        ")\n",
        "\n",
        "# Folder Sementara untuk Proses Video\n",
        "UPLOAD_DIR = \"temp_uploads\"\n",
        "OUTPUT_DIR = \"temp_outputs\"\n",
        "os.makedirs(UPLOAD_DIR, exist_ok=True)\n",
        "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
        "\n",
        "# Mount static files to be served directly by FastAPI\n",
        "app.mount(\"/static\", StaticFiles(directory=OUTPUT_DIR), name=\"static\")\n",
        "\n",
        "# =====================================================================\n",
        "# 1. LANGGRAPH ENGINE CONFIGURATION\n",
        "# =====================================================================\n",
        "class LivestreamState(TypedDict):\n",
        "    face_detected: bool\n",
        "    duration_violating: float\n",
        "    system_alert: str\n",
        "\n",
        "def supervisor_node(state: LivestreamState):\n",
        "    face_present = state.get(\"face_detected\", False)\n",
        "    current_duration = state.get(\"duration_violating\", 0.0)\n",
        "\n",
        "    alert = \"✅ STATUS: PRIVACY CLEAN\"\n",
        "    if face_present:\n",
        "        if current_duration >= 3.0:\n",
        "            alert = f\"🚨 CRITICAL: FACE DETECTED TOO LONG ({current_duration:.1f}s)\"\n",
        "        else:\n",
        "            alert = f\"⚠️ WARNING: SHARIA GUARDRAIL ACTIVE ({current_duration:.1f}s)\"\n",
        "\n",
        "    return {\"system_alert\": alert}\n",
        "\n",
        "def compile_agent():\n",
        "    workflow = StateGraph(LivestreamState)\n",
        "    workflow.add_node(\"supervisor\", supervisor_node)\n",
        "    workflow.set_entry_point(\"supervisor\")\n",
        "    workflow.add_edge(\"supervisor\", END)\n",
        "    return workflow.compile()\n",
        "\n",
        "agent = compile_agent()\n",
        "face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + 'haarcascade_frontalface_default.xml')\n",
        "\n",
        "# =====================================================================\n",
        "# 2. REST API ENDPOINTS\n",
        "# =====================================================================\n",
        "\n",
        "@app.get(\"/\")\n",
        "def read_root():\n",
        "    return {\n",
        "        \"status\": \"online\",\n",
        "        \"engine\": \"Thiqla AI Sharia Guardrail Active\",\n",
        "        \"framework\": \"FastAPI + LangGraph\"\n",
        "    }\n",
        "\n",
        "@app.post(\"/api/v1/sanitize-video\")\n",
        "async def sanitize_video(file: UploadFile = File(...)):\n",
        "    print(f\"[FASTAPI] Received video upload: {file.filename}\") # Log\n",
        "    start_time = time.time() # Start timer for overall process\n",
        "\n",
        "    if not file.filename.endswith(('.mp4', '.avi', '.mov', '.mkv')):\n",
        "        raise HTTPException(status_code=400, detail=\"Format file tidak didukung!\")\n",
        "\n",
        "    timestamp = int(time.time())\n",
        "    input_path = os.path.join(UPLOAD_DIR, f\"input_{timestamp}_{file.filename}\")\n",
        "    output_filename = f\"clean_{timestamp}_{file.filename}\" # Match Streamlit's expected filename format\n",
        "    output_path = os.path.join(OUTPUT_DIR, output_filename)\n",
        "\n",
        "    with open(input_path, \"wb\") as buffer:\n",
        "        shutil.copyfileobj(file.file, buffer)\n",
        "    print(f\"[FASTAPI] Saved input video to: {input_path}\") # Log\n",
        "\n",
        "    cap = cv2.VideoCapture(input_path)\n",
        "    if not cap.isOpened():\n",
        "        raise HTTPException(status_code=500, detail=\"Gagal membaca file video.\")\n",
        "\n",
        "    fps = cap.get(cv2.CAP_PROP_FPS) or 24\n",
        "    width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH)) or 640\n",
        "    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT)) or 360\n",
        "\n",
        "    # Define output resolution. For now, keep original.\n",
        "    output_width, output_height = width, height\n",
        "\n",
        "    fourcc = cv2.VideoWriter_fourcc(*'mp4v')\n",
        "    out = cv2.VideoWriter(output_path, fourcc, fps, (output_width, output_height))\n",
        "\n",
        "    if not out.isOpened():\n",
        "        print(f\"[FASTAPI] Error: Could not open video writer for {output_path}\")\n",
        "        cap.release()\n",
        "        raise HTTPException(status_code=500, detail=\"Gagal membuat file video output.\")\n",
        "\n",
        "    face_detected_status = False\n",
        "    start_detection_time = None\n",
        "    duration_violating = 0.0\n",
        "\n",
        "    frame_count = 0\n",
        "    processing_frames_start_time = time.time()\n",
        "\n",
        "    # Optimization parameters for faster face detection\n",
        "    # Process face detection on a smaller frame (e.g., half size) for speed.\n",
        "    detection_downscale_factor = 0.5\n",
        "    # Slightly reduce minNeighbors for faster detection, might trade off very slight accuracy.\n",
        "    detection_min_neighbors = 5\n",
        "    # Minimum face size to detect on the downscaled frame. (e.g., 40x40 on original is 20x20 on downscaled)\n",
        "    detection_min_size = (int(40 * detection_downscale_factor), int(40 * detection_downscale_factor))\n",
        "\n",
        "    while True:\n",
        "        ret, frame = cap.read()\n",
        "        if not ret:\n",
        "            break\n",
        "\n",
        "        frame_count += 1\n",
        "\n",
        "        # Resize frame to a consistent output size (if output_width, output_height differ from input width, height)\n",
        "        # For now, we assume output_width, output_height are same as original width, height\n",
        "\n",
        "        # Create a smaller version of the frame for faster face detection\n",
        "        small_frame = cv2.resize(frame, (0, 0), fx=detection_downscale_factor, fy=detection_downscale_factor, interpolation=cv2.INTER_AREA)\n",
        "        small_gray = cv2.cvtColor(small_frame, cv2.COLOR_BGR2GRAY)\n",
        "\n",
        "        # Perform face detection on the smaller frame\n",
        "        faces_detected_on_small = face_cascade.detectMultiScale(\n",
        "            small_gray,\n",
        "            scaleFactor=1.1,\n",
        "            minNeighbors=detection_min_neighbors,\n",
        "            minSize=detection_min_size\n",
        "        )\n",
        "\n",
        "        # Scale detected face coordinates back to the original frame size\n",
        "        faces = []\n",
        "        for (x, y, w, h) in faces_detected_on_small:\n",
        "            x_orig = int(x / detection_downscale_factor)\n",
        "            y_orig = int(y / detection_downscale_factor)\n",
        "            w_orig = int(w / detection_downscale_factor)\n",
        "            h_orig = int(h / detection_downscale_factor)\n",
        "            faces.append((x_orig, y_orig, w_orig, h_orig))\n",
        "\n",
        "        if len(faces) > 0:\n",
        "            face_detected_status = True\n",
        "            if start_detection_time is None:\n",
        "                start_detection_time = time.time()\n",
        "            duration_violating = time.time() - start_detection_time\n",
        "\n",
        "            for (x, y, w, h) in faces:\n",
        "                # Ensure coordinates are within frame bounds to prevent errors\n",
        "                y1, y2 = max(0, y), min(height, y + h)\n",
        "                x1, x2 = max(0, x), min(width, x + w)\n",
        "\n",
        "                if y2 > y1 and x2 > x1: # Ensure valid region\n",
        "                    sub_face = frame[y1:y2, x1:x2]\n",
        "                    # Apply Gaussian blur, ensuring kernel size is odd and appropriate for sub_face size\n",
        "                    kernel_size = 99 # A large kernel for strong blur\n",
        "                    if sub_face.shape[0] < kernel_size or sub_face.shape[1] < kernel_size:\n",
        "                        # Fallback for very small faces: adjust kernel size to fit\n",
        "                        kernel_size = min(sub_face.shape[0], sub_face.shape[1])\n",
        "                        kernel_size = kernel_size if kernel_size % 2 == 1 else kernel_size - 1\n",
        "                        kernel_size = max(1, kernel_size) # Ensure kernel_size is at least 1\n",
        "\n",
        "                    if kernel_size > 1: # Only blur if kernel_size is effective\n",
        "                        frame[y1:y2, x1:x2] = cv2.GaussianBlur(sub_face, (kernel_size, kernel_size), 15)\n",
        "                    else:\n",
        "                        # For extremely small faces, might just fill with black\n",
        "                        frame[y1:y2, x1:x2] = (0,0,0)\n",
        "\n",
        "        else:\n",
        "            face_detected_status = False\n",
        "            start_detection_time = None\n",
        "            duration_violating = 0.0\n",
        "\n",
        "        graph_output = agent.invoke({\n",
        "            \"face_detected\": face_detected_status,\n",
        "            \"duration_violating\": duration_violating,\n",
        "            \"system_alert\": \"\"\n",
        "        })\n",
        "        alert_text = graph_output[\"system_alert\"]\n",
        "\n",
        "        text_color = (0, 0, 255) if \"⚠️\" in alert_text or \"🚨\" in alert_text else (0, 255, 0)\n",
        "        # Draw a black rectangle background for the text\n",
        "        cv2.rectangle(frame, (10, 10), (490, 45), (0, 0, 0), -1)\n",
        "        cv2.putText(frame, alert_text, (20, 32), cv2.FONT_HERSHEY_SIMPLEX, 0.45, text_color, 2)\n",
        "\n",
        "        out.write(frame)\n",
        "\n",
        "    cap.release()\n",
        "    out.release()\n",
        "    print(f\"[FASTAPI] Finished processing {frame_count} frames. Frame processing time: {time.time() - processing_frames_start_time:.2f} seconds.\") # Log\n",
        "\n",
        "    if os.path.exists(input_path):\n",
        "        os.remove(input_path)\n",
        "        print(f\"[FASTAPI] Removed input file: {input_path}\") # Log\n",
        "\n",
        "    end_time = time.time() # End timer\n",
        "    print(f\"[FASTAPI] Video sanitation completed in {end_time - start_time:.2f} seconds. Output: {output_path}\") # Log\n",
        "\n",
        "    # Return a JSON response with the URL to the sanitized video\n",
        "    return {\"url\": f\"/static/{output_filename}\"}"
